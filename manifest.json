{
  "manifest_version": 3,
  "name": "MonkeyType Translator – Learn languages while typing",
  "version": "2.3.4",
  "description": "Educational tool for language practice on Monkeytype: translates words while typing and builds your personal dictionary.",
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://monkeytype.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://monkeytype.com/*"],
      "js": [
        "js/common/storage.js",
        "js/common/translator.js",
        "js/common/i18n.js",
        "js/content/tts.js",
        "js/content/panel-ui.js",
        "js/content/inline-ui.js",
        "js/content/mini-dict.js",
        "js/content/toast.js",
        "js/content/observer.js",
        "js/content/theme-engine.js",
        "js/content/main-content.js"
      ],
      "css": ["css/main-ui.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png", "icons/*.svg", "html/*.html", "json/*.json"],
      "matches": ["https://monkeytype.com/*"]
    }
  ]
}
